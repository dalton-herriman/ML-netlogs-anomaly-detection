# Copy to .env and edit as needed. Never commit a real .env.

# --- Model ---
MODEL_PATH=models/xgb_model.joblib
SCALER_PATH=models/scaler.joblib

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO

# --- MLflow ---
# Local file store by default. Point at a tracking server for production runs.
MLFLOW_TRACKING_URI=file:./mlruns
MLFLOW_EXPERIMENT_NAME=anomaly-detection
